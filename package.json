{
  "name": "swik-pixel-swarm",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run vite\"",
    "start": "npm install && pip install -r requirements.txt && concurrently \"python backend/miro_swarm.py\" \"npm run vite\"",
    "vite": "vite --port 5175",
    "backend": "python backend/miro_swarm.py"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "ws": "^8.16.0",
    "zustand": "^4.5.2"
  }
}
