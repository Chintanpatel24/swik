{
  "name": "swik",
  "version": "1.0.0",
  "description": "SWIK — AI Agent Headquarters. A visual multi-agent office that runs locally or on the web.",
  "homepage": "https://github.com/Chintanpatel24/swik",
  "author": "Chintan Patel",
  "license": "MIT",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev":          "concurrently \"npm run backend\" \"npm run vite\" \"wait-on http://localhost:5175 && electron .\"",
    "web":          "concurrently \"npm run backend\" \"npm run vite\"",
    "vite":         "vite --port 5175",
    "backend":      "node backend/src/server.js",
    "build":        "vite build",
    "package:linux":"electron-builder --linux AppImage",
    "package:all":  "electron-builder --linux --win",
    "docker:up":    "docker compose up -d",
    "docker:down":  "docker compose down",
    "docker:logs":  "docker compose logs -f"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.5",
    "express":        "^4.18.3",
    "node-cron":      "^3.0.3",
    "uuid":           "^9.0.0",
    "ws":             "^8.16.0",
    "three":          "^0.163.0",
    "zustand":        "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently":         "^8.2.2",
    "electron":             "^29.1.0",
    "electron-builder":     "^24.9.1",
    "react":                "^18.3.1",
    "react-dom":            "^18.3.1",
    "react-markdown":       "^9.0.1",
    "vite":                 "^5.2.0",
    "wait-on":              "^7.2.0"
  },
  "build": {
    "appId":       "com.swik.hq",
    "productName": "SWIK",
    "copyright":   "Copyright © 2024 Chintan Patel",
    "linux": {
      "target":   ["AppImage", "deb"],
      "category": "Utility",
      "icon":     "public/icon.png"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon":   "public/icon.png"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "dist/**/*",
      "public/**/*"
    ],
    "extraResources": [
      { "from": "backend", "to": "backend" },
      { "from": "public",  "to": "public"  }
    ]
  }
}
