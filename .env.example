# TechScan Agent — Environment Configuration
# Copy this to .env and edit as needed.
# docker-compose reads this automatically.

# ── Ollama model (must be pulled first) ──
# Options: llama3.2 (2GB) | mistral (4GB) | phi3 (1.7GB) | gemma2 (5GB)
OLLAMA_MODEL=llama3.2

# ── Scan frequency ──
SCAN_INTERVAL_MINUTES=30

# ── Timezone for digest timestamps ──
TIMEZONE=Asia/Kolkata
